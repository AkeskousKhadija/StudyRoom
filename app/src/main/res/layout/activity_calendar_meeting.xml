<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F8FAFC">
<LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
<!--  HEADER AMÉLIORÉ  -->
<com.google.android.material.appbar.MaterialToolbar android:layout_width="match_parent" android:layout_height="72dp" android:background="#FFFFFF" android:elevation="4dp" app:title="Calendrier des meetings" app:titleTextColor="#1E293B" app:navigationIcon="@drawable/ic_back" app:navigationIconTint="#5C6BC0">
<TextView android:id="@+id/txtToday" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end" android:text="Aujourd'hui" android:textColor="#5C6BC0" android:textSize="14sp" android:textStyle="bold" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/badge_today" android:layout_marginEnd="16dp"
    tools:ignore="HardcodedText" />
</com.google.android.material.appbar.MaterialToolbar>
<!--  CALENDRIER AMÉLIORÉ  -->
<androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="16dp" app:cardCornerRadius="24dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<!--  En-tête du calendrier avec navigation  -->
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
<TextView android:id="@+id/txtMonthDisplay" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mars 2026" android:textSize="20sp" android:textColor="#1E293B" android:textStyle="bold" tools:text="Mars 2026"
    tools:ignore="HardcodedText" />
<LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
<ImageView android:id="@+id/btnPreviousMonth" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_chevron_left" app:tint="#64748B" android:padding="8dp" android:background="@drawable/circle_ripple" android:layout_marginEnd="8dp" android:contentDescription="Mois précédent"
    tools:ignore="HardcodedText" />
<ImageView android:id="@+id/btnNextMonth" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_chevron_right" app:tint="#64748B" android:padding="8dp" android:background="@drawable/circle_ripple" android:contentDescription="Mois suivant"
    tools:ignore="HardcodedText" />
</LinearLayout>
</LinearLayout>
<!--  Jours de la semaine  -->
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="8dp" android:paddingHorizontal="4dp">

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="LUN"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="MAR"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="MER"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="JEU"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="VEN"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="SAM"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="DIM"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,TextContrastCheck" />
</LinearLayout>
<com.github.sundeepk.compactcalendarview.CompactCalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:padding="4dp"
            app:compactCalendarBackgroundColor="#FFFFFF"
            app:compactCalendarTextColor="#1E293B"
            app:compactCalendarCurrentDayBackgroundColor="#EEF2FF"
            app:compactCalendarCurrentSelectedDayBackgroundColor="#5C6BC0"
            app:compactCalendarEventIndicatorStyle="small_indicator"
            android:scrollbars="vertical"/>
</LinearLayout>
</androidx.cardview.widget.CardView>
<!--  LÉGENDE AMÉLIORÉE  -->
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:paddingHorizontal="16dp" android:paddingBottom="16dp">
<!--  ROUGE  -->
<LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#F8FAFC" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:layout_marginEnd="12dp">
<View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/circle_red_gradient" android:layout_marginEnd="8dp"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="À venir" android:textSize="13sp" android:textColor="#475569" android:textStyle="normal"
    tools:ignore="HardcodedText" />
<TextView android:id="@+id/badgeUpcoming" android:layout_width="20dp" android:layout_height="20dp" android:text="0" android:textSize="11sp" android:textColor="#FFFFFF" android:gravity="center" android:background="@drawable/badge_red" android:layout_marginStart="8dp" android:visibility="gone"
    tools:ignore="HardcodedText" />
</LinearLayout>
<!--  VERT  -->
<LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#F8FAFC" android:paddingHorizontal="12dp" android:paddingVertical="6dp">
<View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/circle_green_gradient" android:layout_marginEnd="8dp"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Passés" android:textSize="13sp" android:textColor="#475569" android:textStyle="normal"
    tools:ignore="HardcodedText" />
<TextView android:id="@+id/badgePast" android:layout_width="20dp" android:layout_height="20dp" android:text="0" android:textSize="11sp" android:textColor="#FFFFFF" android:gravity="center" android:background="@drawable/badge_green" android:layout_marginStart="8dp" android:visibility="gone"
    tools:ignore="HardcodedText" />
</LinearLayout>
</LinearLayout>
<!--  SECTION TITRE DE LA LISTE  -->
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="20dp" android:paddingBottom="8dp" android:gravity="center_vertical">
<TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Meetings du jour" android:textSize="18sp" android:textColor="#1E293B" android:textStyle="bold"
    tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/txtMeetingCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#EEF2FF"
        android:importantForAccessibility="no"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="0 meeting"
        android:textColor="#5C6BC0"
        android:textSize="14sp"
        tools:ignore="HardcodedText,TextContrastCheck" />
</LinearLayout>
<!--  LISTE SCROLLABLE AVEC ESPACEMENT  -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        tools:ignore="SpeakableTextPresentCheck">

        <LinearLayout
            android:id="@+id/meetingsListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical" />
    </ScrollView>
<!--  MESSAGE SI AUCUN MEETING  -->
<LinearLayout android:id="@+id/emptyStateContainer" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="32dp" android:visibility="gone">
<ImageView android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/ic_event_busy" app:tint="#CBD5E1" android:layout_marginBottom="16dp" android:contentDescription="Aucun meeting"
    tools:ignore="HardcodedText" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aucun meeting prévu" android:textSize="18sp" android:textColor="#64748B" android:textStyle="bold" android:layout_marginBottom="8dp"
    tools:ignore="HardcodedText" />
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sélectionnez une date ou ajoutez un nouveau meeting" android:textSize="14sp" android:textColor="#94A3B8" android:gravity="center"
    tools:ignore="HardcodedText" />
</LinearLayout>
</LinearLayout>
<!--  FLOAT BUTTON AMÉLIORÉ  -->
<com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/btnPlanifier" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|end" android:layout_margin="20dp" android:src="@drawable/ic_add" android:contentDescription="Ajouter un meeting" app:backgroundTint="#5C6BC0" app:rippleColor="#FFFFFF" app:borderWidth="0dp" app:elevation="6dp" app:fabSize="normal"
    tools:ignore="HardcodedText" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>