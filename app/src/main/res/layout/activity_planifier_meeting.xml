<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- En-tête avec icône -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="4dp"
                android:layout_height="32dp"
                android:background="@drawable/gradient_purple"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Planifier un meeting"
                android:textSize="28sp"
                android:textColor="#1E293B"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01"
                tools:text="Planifier un meeting"/>

        </LinearLayout>

        <!-- Sujet -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sujet du meeting"
                    android:textSize="14sp"
                    android:textColor="#64748B"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etSujet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ex: Réunion d'équipe hebdomadaire"
                    android:textSize="16sp"
                    android:textColor="#1E293B"
                    android:textColorHint="#94A3B8"
                    android:background="@null"
                    android:paddingVertical="8dp"
                    android:maxLines="3"
                    android:inputType="textMultiLine"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Date -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="#5C6BC0"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date"
                        android:textSize="12sp"
                        android:textColor="#64748B"/>

                    <EditText
                        android:id="@+id/etDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Choisir une date"
                        android:textSize="16sp"
                        android:textColor="#1E293B"
                        android:textColorHint="#94A3B8"
                        android:background="@null"
                        android:focusable="false"
                        android:paddingVertical="4dp"
                        android:cursorVisible="false"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="#94A3B8"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Heure début et fin -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_schedule"
                        android:tint="#5C6BC0"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Début"
                            android:textSize="10sp"
                            android:textColor="#64748B"/>

                        <EditText
                            android:id="@+id/etHeureDebut"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="09:00"
                            android:textSize="15sp"
                            android:textColor="#1E293B"
                            android:textColorHint="#94A3B8"
                            android:background="@null"
                            android:focusable="false"
                            android:paddingVertical="2dp"
                            android:cursorVisible="false"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_schedule"
                        android:tint="#5C6BC0"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fin"
                            android:textSize="10sp"
                            android:textColor="#64748B"/>

                        <EditText
                            android:id="@+id/etHeureFin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="10:00"
                            android:textSize="15sp"
                            android:textColor="#1E293B"
                            android:textColorHint="#94A3B8"
                            android:background="@null"
                            android:focusable="false"
                            android:paddingVertical="2dp"
                            android:cursorVisible="false"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Options supplémentaires -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Options"
                    android:textSize="16sp"
                    android:textColor="#1E293B"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <CheckBox
                    android:id="@+id/checkObligatoire"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Présence obligatoire pour tous"
                    android:textSize="15sp"
                    android:textColor="#334155"
                    android:buttonTint="#5C6BC0"
                    android:paddingVertical="8dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginVertical="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_notifications"
                        android:tint="#64748B"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rappel 15 min avant"
                        android:textSize="14sp"
                        android:textColor="#334155"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchRappel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#5C6BC0"
                        app:trackTint="#C7D2FE"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Bouton créer -->
        <Button
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Créer le meeting"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_gradient_purple"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:elevation="4dp"
            android:layout_marginBottom="16dp"/>

        <!-- Bouton annuler -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Annuler"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_outline"
            android:textAllCaps="false"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>
